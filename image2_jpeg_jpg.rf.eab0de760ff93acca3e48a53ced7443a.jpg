/* Premium Dark Theme */
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap');

:root {
    --bg-main: #0f172a;
    --bg-card: rgba(30, 41, 59, 0.65);
    --text-main: #f8fafc;
    --text-muted: #94a3b8;
    --accent: #3b82f6;
    --accent-hover: #60a5fa;
    --danger: #ef4444;
    --success: #10b981;
    --warning: #f59e0b;
    --border: rgba(255, 255, 255, 0.1);
}

body {
    font-family: 'Inter', sans-serif;
    background-color: var(--bg-main);
    color: var(--text-main);
    margin: 0;
    padding: 0;
    min-height: 100vh;
    background-image: 
        radial-gradient(circle at 15% 50%, rgba(59, 130, 246, 0.12), transparent 30%),
        radial-gradient(circle at 85% 30%, rgba(16, 185, 129, 0.12), transparent 30%);
    background-attachment: fixed;
    line-height: 1.6;
}

.container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 20px;
}

h2, h3 {
    text-align: center;
    color: #e2e8f0;
    font-weight: 600;
    margin-bottom: 24px;
}

h2 {
    font-size: 2.2rem;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, #f8fafc 0%, #94a3b8 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
}

h3 {
    font-size: 1.4rem;
    margin-top: 0;
}

.form-card {
    background: var(--bg-card);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: 30px;
    border-radius: 16px;
    border: 1px solid var(--border);
    box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.5);
    margin-top: 30px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.form-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 15px 35px -10px rgba(0, 0, 0, 0.6);
}

button {
    background: linear-gradient(135deg, var(--accent) 0%, #2563eb 100%);
    color: white;
    border: none;
    padding: 12px 24px;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(59, 130, 246, 0.4);
}

button:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(59, 130, 246, 0.6);
}

button:active {
    transform: translateY(1px);
}

select, input[type="file"] {
    background: rgba(15, 23, 42, 0.5);
    color: var(--text-main);
    border: 1px solid var(--border);
    padding: 10px;
    border-radius: 8px;
    font-family: 'Inter', sans-serif;
    margin-top: 5px;
}

select {
    cursor: pointer;
}

#result {
    margin-top: 25px;
    font-size: 1.1rem;
    font-weight: 400;
    text-align: center;
    color: #cbd5e1;
    padding: 15px;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.05);
}

/* Dashboard Cards */
.card-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    margin-top: 30px;
}

.card {
    background: var(--bg-card);
    backdrop-filter: blur(12px);
    padding: 24px;
    text-align: center;
    border-radius: 16px;
    border: 1px solid var(--border);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.2);
    transition: transform 0.3s ease;
}

.card:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.2);
}

.card h3 {
    color: var(--text-muted);
    font-size: 1.1rem;
    font-weight: 400;
    margin-bottom: 12px;
}

.card p {
    font-size: 2.5rem;
    font-weight: 700;
    margin: 0;
    background: linear-gradient(135deg, #f8fafc 0%, #94a3b8 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
}

.pie-chart-wrap {
    width: 350px;
    height: 350px;
    margin: 40px auto;
    position: relative;
}

@media (max-width: 600px) {
    .pie-chart-wrap {
        width: 250px;
        height: 250px;
    }
}

.suggestion {
    margin-top: 30px;
    padding: 20px;
    border-radius: 12px;
    background-color: rgba(245, 158, 11, 0.1);
    color: var(--warning);
    border: 1px solid rgba(245, 158, 11, 0.2);
    text-align: center;
}

.suggestion h3 {
    color: var(--warning);
    margin: 0;
}

.nav {
    text-align: center;
    margin-top: 40px;
    padding-bottom: 20px;
}

.nav a {
    text-decoration: none;
    color: var(--text-muted);
    font-weight: 600;
    transition: color 0.3s ease;
    padding: 8px 16px;
    border-radius: 8px;
    background: rgba(255,255,255,0.05);
}

.nav a:hover {
    color: var(--text-main);
    background: rgba(255,255,255,0.1);
}

.helper-text {
    margin: 8px 0 16px;
    color: var(--text-muted);
    text-align: center;
    font-size: 0.95rem;
}

.action-link {
    display: inline-block;
    text-decoration: none;
    background: rgba(59, 130, 246, 0.1);
    color: var(--accent-hover);
    padding: 10px 20px;
    border-radius: 8px;
    margin-right: 12px;
    font-weight: 600;
    border: 1px solid rgba(59, 130, 246, 0.3);
    transition: all 0.3s;
}

.action-link:hover {
    background: rgba(59, 130, 246, 0.2);
    border-color: var(--accent);
}

.action-link.secondary {
    background: rgba(148, 163, 184, 0.1);
    color: var(--text-main);
    border-color: rgba(148, 163, 184, 0.3);
}

.action-link.secondary:hover {
    background: rgba(148, 163, 184, 0.2);
    border-color: var(--text-muted);
}

.cm-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    margin-top: 20px;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
}

.cm-table th, .cm-table td {
    border-bottom: 1px solid var(--border);
    border-right: 1px solid var(--border);
    padding: 14px;
    text-align: center;
}

.cm-table th {
    background-color: rgba(0, 0, 0, 0.2);
    color: var(--text-muted);
    font-weight: 600;
}

.cm-table tr:last-child td {
    border-bottom: none;
}
.cm-table th:last-child, .cm-table td:last-child {
    border-right: none;
}

.cell-high { background-color: rgba(16, 185, 129, 0.2); color: #34d399; }
.cell-mid { background-color: rgba(245, 158, 11, 0.15); color: #fbbf24; }
.cell-low { background-color: rgba(239, 68, 68, 0.15); color: #f87171; }

.image-preview-container {
    display: flex;
    justify-content: space-around;
    flex-wrap: wrap;
    gap: 20px;
    margin-top: 30px;
}

.image-box {
    flex: 1;
    min-width: 300px;
    background: rgba(0, 0, 0, 0.2);
    border-radius: 12px;
    padding: 15px;
    text-align: center;
    border: 1px solid var(--border);
}

.image-box img {
    max-width: 100%;
    border-radius: 8px;
    max-height: 400px;
    object-fit: contain;
}

.image-box h4 {
    margin-top: 0;
    color: var(--text-muted);
    font-weight: 400;
}
